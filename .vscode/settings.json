{
  // Register the cburr theme so `theme: cburr` resolves in the Marp for VS Code
  // preview (the extension runs its own Marp and ignores .marprc.yml).
  "markdown.marp.themes": ["./theme/cburr.css"],

  // Allow the raw HTML some layouts use (comparison columns, diagram grid,
  // footnotes, the title-slide blocks).
  "markdown.marp.html": "all",
  "cSpell.words": [
    "transformationss"
  ]

  // NOTE: the extension has no custom-engine support, so it cannot run
  // scripts/marp-engine.mjs. The generated title slide, kicker and auto-footer
  // will NOT show in this preview — use `pixi run dev <folder>` for the
  // faithful render. The preview is still useful for content + layout classes.
}
